rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is a member of a child document
    function isMember(childId) {
      let child = get(/databases/$(database)/documents/children/$(childId));
      return request.auth != null && (
        request.auth.uid == child.data.ownerId ||
        request.auth.uid == child.data.userId ||
        (child.data.memberIds != null && request.auth.uid in child.data.memberIds)
      );
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Children
    match /children/{childId} {
      // Read if already a member
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.ownerId ||
        request.auth.uid == resource.data.userId ||
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );

      // Create: only if the creator includes themselves in memberIds
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.memberIds;

      // Update: only existing members
      allow update: if isMember(childId);

      // Delete: only the owner
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.ownerId ||
        request.auth.uid == resource.data.userId
      );

      // Growth records subcollection
      match /records/{recordId} {
        allow read, write: if isMember(childId);
      }

      // Meta (vaccines, vaccinationRecords, etc.)
      match /meta/{metaId} {
        allow read, write: if isMember(childId);
      }

      // Invite log
      match /inviteLog/{logId} {
        allow read, write: if isMember(childId) || request.auth != null;
      }
    }

    // Invite codes: anyone can read, auth users can create
    match /invites/{code} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.createdBy;
    }
  }
}
